GEMINI_API_KEY=your-hackathon-gemini-key-here
GITHUB_TOKEN=your-hackathon-github-token-here

# AWS S3 — for artifact storage
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=ap-south-1
S3_BUCKET=train-the-brain-artifacts

# SQLite path (default: train_the_brain.db in backend/)
DB_PATH=train_the_brain.db
